// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppStatus {
  PUBLISHED
  IN_REVIEW
  PENDING_REVIEW
  PENDING_PUBLICATION
  REJECTED
  ACTION_REQUIRED
  UPDATE_AVAILABLE
  STORE_ISSUES
}

enum Platform {
  ANDROID
  IOS
}

model App {
  id               String          @id @default(uuid())
  name             String
  entity           String?         // BSJ, BSF, etc.
  storeStatus      String?         // Estado de la aplicación
  updateStatus     String?         // Estado de actualización
  bundleId         String
  platform         Platform
  currentVersion   String?
  buildNumber      String?
  status           AppStatus
  lastUpdate       DateTime?       @default(now())
  rejectionMessage String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  statusHistory    StatusHistory[]
  storeUrl         String?         // URL for redirection to store console

  @@unique([bundleId, platform])
  @@index([platform])
  @@index([status])
}

model StatusHistory {
  id        String   @id @default(uuid())
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  appId     String
  oldStatus AppStatus?
  newStatus AppStatus
  changedAt DateTime @default(now())

  @@index([appId])
}

enum Role {
  ADMIN
  DEVELOPER
  READER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String?
  role          Role      @default(READER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StoreConfig {
  id         String   @id @default(uuid())
  platform   Platform @unique
  configJson Json     // Store encrypted service accounts/API keys
  updatedAt  DateTime @updatedAt
}
model SyncHistory {
  id             String    @id @default(uuid())
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  status         String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, FAILED
  triggeredBy    String    // User email or name
  totalApps      Int
  processedApps  Int       @default(0)
  errorMessage   String?

  @@index([startedAt])
}
